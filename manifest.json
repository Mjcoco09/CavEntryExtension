
{
    "manifest_version": 3,
    "name": "Form Autofill Pro",
    "version": "1.0",
    "permissions": ["activeTab", "scripting", "storage"],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
},
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
        "16": "icon16.png"
    }
        
    },
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_end"
    }]
}